# Скопируйте в .env и впишите LLM_API_KEY. .env в .gitignore — НИКОГДА не коммитить.
# Всё, кроме ключа, уже заполнено рабочими значениями (GPTunnel + deepseek-v4-flash).

# ── LLM: любой OpenAI-совместимый эндпоинт ────────────────────────────────────
LLM_BASE_URL=https://gptunnel.ru/v1
LLM_API_KEY=                                 # ← единственное, что нужно вписать
LLM_MODEL_STRONG=deepseek-v4-flash           # генерация гипотез, сравнение
LLM_MODEL_FAST=deepseek-v4-flash             # извлечение, judge, чат, восстановление
LLM_AUTH_STYLE=raw                           # raw = Authorization без "Bearer " (GPTunnel); bearer = стандарт
LLM_EXTRA_BODY={"useWalletBalance": true}    # JSON, мёржится в тело каждого запроса; пусто = ничего
# Без ключа весь пайплайн работает на моках: гипотезы-заглушки с реальными цитатами,
# БЗ отдаёт фрагменты без LLM-синтеза. С ключом — живые вызовы.

# ── Эмбеддинг для базы знаний ─────────────────────────────────────────────────
EMBED_MODEL=BAAI/bge-m3                       # точнее; на CPU медленно (~700 чанков — минуты)
#EMBED_MODEL=intfloat/multilingual-e5-small   # быстрый fallback (меньше, легче для CPU)
# При смене модели индекс БЗ автоматически переиндексируется под новую размерность.

# ── Хост-порт для docker-деплоя (читается docker compose при `up`) ────────────
# По умолчанию 127.0.0.1:8012 (за системным nginx). Деплой «по порту» без домена:
# передайте в команде  →  WEB_BIND=0.0.0.0:8080 docker compose ... up -d
#WEB_BIND=0.0.0.0:8080

# ── Тумблеры генерации гипотез (по желанию) ───────────────────────────────────
#GEN_NO_REPAIR=1                              # не до-генерировать недостающие направления вторым вызовом
#GEN_NO_FEWSHOT=1                             # убрать few-shot-примеры из промпта генерации
#HF_TOKEN=                                    # необязательно: снимает варнинг HF Hub, ускоряет загрузку модели

# ── Альтернатива: Yandex AI Studio ────────────────────────────────────────────
#LLM_BASE_URL=https://ai.api.cloud.yandex.net/v1
#LLM_MODEL_STRONG=gpt://<folder_id>/deepseek-v4-flash/latest
#LLM_MODEL_FAST=gpt://<folder_id>/deepseek-v4-flash/latest
#LLM_AUTH_STYLE=bearer
#LLM_EXTRA_BODY=
