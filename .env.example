# Скопируйте в .env и заполните. .env в .gitignore, НИКОГДА не коммитить.
LLM_BASE_URL=https://gptunnel.ru/v1
LLM_API_KEY=
LLM_MODEL_STRONG=deepseek-v4-pro   # генерация гипотез, сравнение (thinking)
LLM_MODEL_FAST=deepseek-v4-pro     # извлечение, judge, чат, восстановление
LLM_AUTH_STYLE=raw                 # raw = заголовок Authorization без "Bearer " (GPTunnel), bearer = стандарт
LLM_EXTRA_BODY={"useWalletBalance": true}   # JSON, мёржится в тело каждого запроса; пусто = ничего
EMBED_MODEL=BAAI/bge-m3            # fallback: intfloat/multilingual-e5-small
