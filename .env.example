# Скопируйте в .env и заполните. .env в .gitignore, НИКОГДА не коммитить.
# Подходит любой OpenAI-совместимый эндпоинт. Два проверенных варианта:

# --- Yandex AI Studio (рекомендуется: deepseek-v4-flash быстрый) ---
LLM_BASE_URL=https://ai.api.cloud.yandex.net/v1
LLM_API_KEY=
LLM_MODEL_STRONG=gpt://<folder_id>/deepseek-v4-flash/latest   # генерация гипотез, сравнение
LLM_MODEL_FAST=gpt://<folder_id>/deepseek-v4-flash/latest     # извлечение, judge, чат, восстановление
LLM_AUTH_STYLE=bearer
LLM_EXTRA_BODY=
EMBED_MODEL=BAAI/bge-m3            # fallback: intfloat/multilingual-e5-small

# --- GPTunnel (альтернатива) ---
# LLM_BASE_URL=https://gptunnel.ru/v1
# LLM_MODEL_STRONG=deepseek-v4-pro
# LLM_MODEL_FAST=deepseek-v4-pro
# LLM_AUTH_STYLE=raw               # raw = заголовок Authorization без "Bearer "
# LLM_EXTRA_BODY={"useWalletBalance": true}   # JSON, мёржится в тело каждого запроса
