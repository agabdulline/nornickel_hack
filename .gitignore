# секреты — НИКОГДА не коммитить
.env

# исходники кейса и архив (лежат локально, read-only);
# исключения: внешние источники БЗ и готовый OCR-результат — в репозитории,
# они нужны для воспроизводимого деплоя (тяжёлые книги data/kb/books не включаем)
data/*
!data/kb/
data/kb/*
!data/kb/extra/
!data/kb/ocr/
!data/kb/sources.csv
*.zip

# рантайм-хранилище (sqlite, индексы KB, кэш моделей)
storage/
models_cache/
chroma/

# python
__pycache__/
*.pyc
.pytest_cache/
.venv/
venv/

# node
node_modules/
frontend/dist/

# прочее
.DS_Store
*.log
